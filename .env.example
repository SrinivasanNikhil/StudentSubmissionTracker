# Copy this file to .env and fill in real values. Never commit .env.

# Application
PORT=3000
NODE_ENV=development
SESSION_SECRET=replace-with-a-long-random-string
APP_URL=http://localhost:3000

# SQL Practice Databases (ClassicModels / northwind / Text)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=ClassicModels

# Application Database (SQLPracticeApp)
APP_DB_HOST=localhost
APP_DB_PORT=3306
APP_DB_USER=your_app_db_user
APP_DB_PASSWORD=your_app_db_password
APP_DB_NAME=SQLPracticeApp

# OpenAI
OPENAI_API_KEY=sk-replace-with-your-api-key

# SMTP (password reset email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# Production proxy/SSL settings
TRUST_PROXY=false
HTTPS=false
