<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="/">
            <span class="navbar-brand-icon">NS</span>
            SQL Practice
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <% if (locals.user) { %>
                    <li class="nav-item">
                        <a class="nav-link <%= locals.currentPath === '/topics' ? 'active' : '' %>"
                           href="/topics">Topics</a>
                    </li>
                <% } %>
            </ul>
            <ul class="navbar-nav align-items-center gap-1">
                <% if (locals.user) { %>
                    <% if (locals.user.isAdmin===true || locals.user.role==='admin') { %>
                        <li class="nav-item">
                            <a class="nav-link <%= locals.currentPath && locals.currentPath.startsWith('/admin') ? 'active' : '' %>"
                               href="/admin">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= locals.currentPath === '/admin/users' ? 'active' : '' %>"
                               href="/admin/users">Users</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= locals.currentPath === '/admin/instructors' ? 'active' : '' %>"
                               href="/admin/instructors">Instructors</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= locals.currentPath && locals.currentPath.startsWith('/er-diagrams') ? 'active' : '' %>"
                               href="/er-diagrams/admin/submissions">Submissions</a>
                        </li>
                    <% } else if (locals.user.role==='instructor') { %>
                        <li class="nav-item">
                            <a class="nav-link <%= locals.currentPath && locals.currentPath.startsWith('/instructor') ? 'active' : '' %>"
                               href="/instructor/dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= locals.currentPath === '/instructor/students' ? 'active' : '' %>"
                               href="/instructor/students">Students</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= locals.currentPath === '/instructor/submissions' ? 'active' : '' %>"
                               href="/instructor/submissions">Submissions</a>
                        </li>
                    <% } %>
                    <li class="nav-item ms-2">
                        <a href="/profile" class="nav-link p-0"
                           title="<%= locals.user.firstName %> <%= locals.user.lastName %>">
                            <span class="nav-avatar">
                                <%= locals.user.firstName ? locals.user.firstName.charAt(0).toUpperCase() : '' %><%= locals.user.lastName ? locals.user.lastName.charAt(0).toUpperCase() : '' %>
                            </span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/auth/logout" style="color: var(--muted) !important;"
                           title="Logout">
                            <i class="bi bi-box-arrow-right"></i>
                        </a>
                    </li>
                <% } else { %>
                    <li class="nav-item">
                        <a class="nav-link <%= locals.currentPath === '/auth/login' ? 'active' : '' %>"
                           href="/auth/login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary btn-sm ms-2 px-3" href="/auth/register">Register</a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>
