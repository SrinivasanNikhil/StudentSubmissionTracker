<div class="container">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                <li class="breadcrumb-item"><a href="/admin">Admin Dashboard</a></li>
            <% } else { %>
                <li class="breadcrumb-item"><a href="/instructor/dashboard">Instructor Dashboard</a></li>
            <% } %>
            <li class="breadcrumb-item active" aria-current="page">Export by Topic</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Export by Topic</h1>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Select Topics to Export</h5>
        </div>
        <div class="card-body">
            <p class="text-muted mb-4">
                Select the topics you want to include in the export. The CSV will contain one row per student
                with columns showing completion counts (completed/total) for each selected topic.
            </p>

            <form action="<%= typeof isAdmin !== 'undefined' && isAdmin ? '/admin/export/by-topic' : '/instructor/export/by-topic' %>" method="GET" id="exportForm">
                <!-- Semester Filter -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Filter by Semester (Optional)</label>
                    <div class="row">
                        <div class="col-md-4 mb-2">
                            <label class="form-label" for="academicYear">Academic Year</label>
                            <select class="form-select" id="academicYear" name="academicYear">
                                <option value="all">All Academic Years</option>
                                <% if (typeof academicYears !== 'undefined' && academicYears.length > 0) { %>
                                    <% academicYears.forEach(year => { %>
                                        <option value="<%= year %>"><%= year %></option>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label" for="semester">Semester</label>
                            <select class="form-select" id="semester" name="semester">
                                <option value="all">All Semesters</option>
                                <% if (typeof semesters !== 'undefined' && semesters.length > 0) { %>
                                    <% semesters.forEach(sem => { %>
                                        <option value="<%= sem %>"><%= sem %></option>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label" for="courseSection">Course Section</label>
                            <select class="form-select" id="courseSection" name="courseSection">
                                <option value="all">All Course Sections</option>
                                <% if (typeof courseSections !== 'undefined' && courseSections.length > 0) { %>
                                    <% courseSections.forEach(section => { %>
                                        <option value="<%= section.identifier %>"><%= section.displayName %></option>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>
                    </div>
                    <small class="text-muted">Leave as "All" to include students from all semesters and sections.</small>
                </div>

                <hr class="my-4">

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <label class="form-label fw-bold mb-0">Topics</label>
                        <div>
                            <button type="button" class="btn btn-sm btn-outline-secondary me-2" id="selectAll">
                                Select All
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="deselectAll">
                                Deselect All
                            </button>
                        </div>
                    </div>

                    <% if (topics.length === 0) { %>
                        <div class="alert alert-warning">
                            No topics available for export.
                        </div>
                    <% } else { %>
                        <div class="row">
                            <% topics.forEach((topic, index) => { %>
                                <div class="col-md-6 col-lg-4 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input topic-checkbox" type="checkbox"
                                               name="topicIds" value="<%= topic.id %>"
                                               id="topic-<%= topic.id %>" checked>
                                        <label class="form-check-label" for="topic-<%= topic.id %>">
                                            <%= topic.name %>
                                            <span class="badge bg-secondary ms-1"><%= topic.questionCount %> questions</span>
                                        </label>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } %>
                </div>

                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Export Preview:</strong> The CSV will include columns for Email, Name, Code,
                    and one column per selected topic showing "completed/total" (e.g., "3/5").
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                        <a href="/admin" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                        </a>
                    <% } else { %>
                        <a href="/instructor/students" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Back to Students
                        </a>
                    <% } %>
                    <button type="submit" class="btn btn-primary" id="exportBtn" <%= topics.length === 0 ? 'disabled' : '' %>>
                        <i class="bi bi-download me-1"></i> Export CSV
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const selectAllBtn = document.getElementById('selectAll');
    const deselectAllBtn = document.getElementById('deselectAll');
    const checkboxes = document.querySelectorAll('.topic-checkbox');
    const exportBtn = document.getElementById('exportBtn');
    const form = document.getElementById('exportForm');

    function updateExportButton() {
        const checkedCount = document.querySelectorAll('.topic-checkbox:checked').length;
        exportBtn.disabled = checkedCount === 0;
    }

    selectAllBtn.addEventListener('click', function() {
        checkboxes.forEach(cb => cb.checked = true);
        updateExportButton();
    });

    deselectAllBtn.addEventListener('click', function() {
        checkboxes.forEach(cb => cb.checked = false);
        updateExportButton();
    });

    checkboxes.forEach(cb => {
        cb.addEventListener('change', updateExportButton);
    });

    form.addEventListener('submit', function(e) {
        const checkedCount = document.querySelectorAll('.topic-checkbox:checked').length;
        if (checkedCount === 0) {
            e.preventDefault();
            alert('Please select at least one topic to export.');
        }
    });
});
</script>

<style>
    .form-check {
        padding: 0.5rem 0.5rem 0.5rem 2rem;
        border-radius: 0.375rem;
        transition: background-color 0.2s;
    }

    .form-check:hover {
        background-color: #f8f9fa;
    }

    .card {
        transition: all 0.2s ease-in-out;
    }

    .card:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }
</style>
