<div class="container mt-4">
    <div class="mx-auto" style="max-width: 1200px; margin-left: 2rem; margin-right: 2rem;">
        <!-- Breadcrumb Navigation -->
        <nav aria-label="breadcrumb" class="mb-4">
            <div class="d-flex align-items-center justify-content-between">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/topics">Topics</a></li>
                    <li class="breadcrumb-item">
                        <a href="/questions/topic/<%= question.topicId %>"><%= question.topic.name %></a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        Q<%= questionIndex %> of <%= totalQuestions %>
                    </li>
                </ol>
                <div class="d-flex gap-2">
                    <% if (typeof prevId !== 'undefined' && prevId) { %>
                        <a href="/questions/<%= prevId %>"
                           class="btn btn-sm btn-outline-secondary"
                           title="Previous question">
                            <i class="bi bi-chevron-left"></i> Prev
                        </a>
                    <% } %>
                    <% if (typeof nextId !== 'undefined' && nextId) { %>
                        <a href="/questions/<%= nextId %>"
                           class="btn btn-sm btn-outline-secondary"
                           title="Next question">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    <% } %>
                </div>
            </div>
        </nav>

        <!-- Question Card -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center bg-light">
                <h4 class="mb-0">
                    <i class="bi bi-question-circle me-2"></i>
                    Question #<%= question.id %>
                </h4>
                <div class="d-flex align-items-center gap-2">
                    <% if (completed) { %>
                        <span class="badge rounded-pill px-3 py-2 completion-badge-complete"
                              id="completion-badge">
                            <i class="bi bi-check-circle-fill me-1"></i> Completed
                        </span>
                    <% } else if (!solutionUnlocked) { %>
                        <span class="badge rounded-pill px-3 py-2 completion-badge-incomplete"
                              id="completion-badge">
                            <i class="bi bi-circle me-1"></i> Not completed
                        </span>
                        <span class="text-muted small" id="unlock-progress-label"
                              title="Attempt at least 5 times with 75%+ row match to unlock the solution">
                            <i class="bi bi-lock me-1"></i>
                            Solution: <%= attemptCount %>/5 attempts<% if (attemptCount > 0) { %>, <%= bestRowMatchPct %>% match<% } %>
                        </span>
                    <% } else { %>
                        <span class="badge rounded-pill px-3 py-2 completion-badge-incomplete"
                              id="completion-badge">
                            <i class="bi bi-circle me-1"></i> Not completed
                        </span>
                        <span class="text-muted small" id="unlock-progress-label">
                            <i class="bi bi-unlock me-1"></i> Solution unlocked
                        </span>
                    <% } %>
                </div>
            </div>
            <div class="card-body">
                <h5 class="card-title text-muted">
                    <i class="bi bi-database me-2"></i>
                    Topic: <%= question.topic.name %>
                </h5>
                <p class="card-text lead">
                    <%= question.questionText %>
                </p>

                <div class="mt-4" id="completion-rules-alert">
                    <div class="alert alert-info alert-dismissible d-flex align-items-start gap-2" role="alert"
                         style="font-size:0.875rem;">
                        <i class="bi bi-info-circle-fill flex-shrink-0 mt-1"></i>
                        <div>
                            Marked complete when your query returns the same number of rows <em>and</em> columns as the reference.
                            Column aliases and ordering don't matter.
                        </div>
                        <button type="button" class="btn-close ms-auto flex-shrink-0"
                                onclick="dismissRulesAlert()" aria-label="Close"></button>
                    </div>
                </div>

                <script>
                function dismissRulesAlert() {
                    document.getElementById('completion-rules-alert').style.display = 'none';
                    try { localStorage.setItem('sst_rules_dismissed', '1'); } catch(e) {}
                }
                document.addEventListener('DOMContentLoaded', function() {
                    try {
                        if (localStorage.getItem('sst_rules_dismissed') === '1') {
                            const el = document.getElementById('completion-rules-alert');
                            if (el) el.style.display = 'none';
                        }
                    } catch(e) {}
                });
                </script>
            </div>
        </div>

        <!-- SQL Query Editor Section -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="bi bi-code-square me-2"></i>
                    SQL Query Editor
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <!-- Query Editor Column -->
                    <div class="col-md-8">
                        <!-- Database info + schema modal trigger -->
                        <div class="mb-3 d-flex align-items-center gap-2">
                            <span class="text-muted small">
                                <i class="bi bi-database me-1"></i>
                                Database: <strong><%= question.topic.database %></strong>
                            </span>
                            <button type="button" class="btn btn-sm btn-outline-secondary py-0"
                                    data-bs-toggle="modal" data-bs-target="#schemaModal"
                                    style="font-size:12px;">
                                <i class="bi bi-table me-1"></i>View Schema
                            </button>
                        </div>

                        <div class="form-group mb-3">
                            <label for="sqlQuery" class="form-label">Your SQL Query</label>
                            <div class="sql-editor-wrapper">
                                <textarea class="code-editor" id="sqlQuery" rows="8"
                                    placeholder="-- Write your SQL query here..."></textarea>
                                <div class="sql-editor-toolbar">
                                    <button id="executeQueryBtn" class="btn btn-sm btn-primary">
                                        <i class="bi bi-play-fill me-2"></i> Execute Query
                                    </button>
                                    <button id="clearQueryBtn" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eraser me-2"></i> Clear
                                    </button>
                                    <button id="aiFeedbackBtn" type="button" class="btn btn-sm btn-outline-info ms-2">
                                        <i class="bi bi-robot me-1"></i> Get AI Feedback
                                    </button>
                                    <span class="ms-auto text-muted small" id="query-char-count" style="color:#8888aa !important;"></span>
                                    <span style="color:#6c6fc4; font-size:11px; margin-left:8px; flex-shrink:0;">
                                        <kbd style="background:#2a2a4a; border:1px solid #3a3a5c; border-radius:3px; padding:1px 5px; font-size:10px; color:#a0a0c0;">Ctrl</kbd>
                                        +
                                        <kbd style="background:#2a2a4a; border:1px solid #3a3a5c; border-radius:3px; padding:1px 5px; font-size:10px; color:#a0a0c0;">↵</kbd>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- AI Feedback Column -->
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-header" style="background:linear-gradient(135deg, #4f46e5, #7c3aed); color:#fff;">
                                <h6 class="mb-0">
                                    <i class="bi bi-robot me-2"></i>AI Feedback
                                </h6>
                            </div>
                            <div class="card-body">
                                <div id="realtime-feedback">
                                    <div class="text-muted small">
                                        <i class="bi bi-robot me-2"></i>
                                        Click <strong>Get AI Feedback</strong> in the toolbar for syntax hints on your current query.
                                    </div>
                                </div>
                                <div id="realtime-loading" style="display: none;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="spinner-border spinner-border-sm text-primary" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                        <small class="text-muted">Analyzing...</small>
                                    </div>
                                </div>
                            </div>
                            <% if (solutionUnlocked) { %>
                            <div class="card-footer bg-transparent border-top pt-2">
                                <div id="reference-query-container" style="display:none;">
                                    <pre class="bg-light p-2 rounded mb-2" style="font-size:12px;"><code id="reference-query"><%= solutionQuery %></code></pre>
                                </div>
                                <div class="d-flex gap-2 flex-wrap">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="showReferenceQueryBtn">
                                        <i class="bi bi-code-square me-1"></i>
                                        <span id="showReferenceQueryLabel">Show solution</span>
                                    </button>
                                    <button id="compareWithChatGPT" class="btn btn-sm btn-primary">
                                        <i class="bi bi-robot me-1"></i>Compare with AI
                                    </button>
                                </div>
                                <div id="chatgpt-analysis" class="mt-3" style="display:none;">
                                    <div id="chatgpt-loading" class="text-center" style="display:none;">
                                        <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
                                    </div>
                                    <div id="chatgpt-content"></div>
                                </div>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SQL Query Results Section -->
        <div id="results-section" style="display: none;">
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-table me-2"></i>
                        Query Results
                    </h5>
                </div>
                <div class="card-body">
                    <div id="execution-status" class="mb-3">&nbsp;</div>

                    <div class="table-responsive">
                        <table id="results-table" class="table table-striped table-bordered">
                            <thead id="results-thead"></thead>
                            <tbody id="results-tbody"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Query Feedback Section -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-graph-up me-2"></i>
                        Query Match Summary
                    </h5>
                </div>
                <div class="card-body">
                    <div id="feedback-box" class="alert mb-3" role="alert"></div>

                    <div id="differences-container">
                        <!-- Solution section: always rendered; only used for unlock state tracking -->
                        <div id="solution-section" <% if (!solutionUnlocked) { %>style="display:none"<% } %>></div>
                        <!-- Lock notice: always rendered; hidden via CSS when unlocked on load -->
                        <div id="solution-lock-notice" class="alert alert-secondary mb-3" <% if (solutionUnlocked) { %>style="display:none"<% } %>>
                            <i class="bi bi-lock me-2"></i>
                            <strong>Solution locked.</strong>
                            Complete at least 5 attempts with at least 75% of the expected rows matched to unlock the solution.
                            <br><small class="text-muted">
                                Current progress: <%= attemptCount %> attempt<%= attemptCount !== 1 ? 's' : '' %>,
                                best row match: <%= bestRowMatchPct %>%
                            </small>
                        </div>
                        <h6 class="text-muted mb-3">
                            <i class="bi bi-list-check me-2"></i>
                            Query Comparison:
                        </h6>
                        <ul id="differences-list" class="list-group"></ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <a href="/questions/topic/<%= question.topicId %>" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-2"></i>
                Back to Questions
            </a>
        </div>
    </div>
</div>

<!-- Schema Modal -->
<div class="modal fade" id="schemaModal" tabindex="-1" aria-labelledby="schemaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="schemaModalLabel">
                    <i class="bi bi-database me-2"></i>
                    <%= question.topic.database %> Schema
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <% if (question.topic.database === 'ClassicModels') { %>
                    <pre class="bg-light p-3 rounded" style="font-size:13px;"><code>Customers (customerNumber, customerName, contactLastName, contactFirstName, phone,
           addressLine1, addressLine2, city, state, postalCode, country,
           salesRepEmployeeNumber, creditLimit)
Employees (employeeNumber, lastName, firstName, extension, email,
           officeCode, reportsTo, jobTitle)
Offices   (officeCode, city, phone, addressLine1, addressLine2,
           state, country, postalCode, territory)
Orders    (orderNumber, orderDate, requiredDate, shippedDate, status,
           comments, customerNumber)
OrderDetails (orderNumber, productCode, quantityOrdered, priceEach, orderLineNumber)
Payments  (customerNumber, checkNumber, paymentDate, amount)
Products  (productCode, productName, productLine, productScale, productVendor,
           productDescription, quantityInStock, buyPrice, MSRP)
ProductLines (productLine, textDescription, htmlDescription, image)</code></pre>
                <% } else if (question.topic.database === 'Text') { %>
                    <pre class="bg-light p-3 rounded" style="font-size:13px;"><code>shr (shrcode, shrfirm, shrprice, shrqty, shrdiv, shrpe)
share (shrcode, shrfirm, shrprice, shrqty, shrdiv, shrpe)
stock (stkcode, stkfirm, stkprice, stkqty, stkdiv, stkpe, natcode)
stockvalue (stkfirm, stkprice, stkqty, exchrate, stkvalue)
emp (empno, empfname, empsalary, deptname, bossno)
dept (deptname, deptfloor, deptphone, empno)
product (prodid, proddesc, prodcost, prodprice)
sale (saleno, saledate, saletext)
lineitem (lineno, lineqty, lineprice, saleno, itemno)
item (itemno, itemname, itemtype, itemcolor)
nation (natcode, natname, exchrate)
person (personid, person first, person last)
car (carid, carcost, carsell, cartype, personid)</code></pre>
                <% } else { %>
                    <pre class="bg-light p-3 rounded" style="font-size:13px;"><code>Categories (CategoryID, CategoryName, Description, Picture)
Customers (CustomerID, CompanyName, ContactName, ContactTitle, Address, City, Region, PostalCode, Country, Phone, Fax)
Employees (EmployeeID, LastName, FirstName, Title, TitleOfCourtesy, BirthDate, HireDate, Address, City, Region, PostalCode, Country, HomePhone, Extension, Photo, Notes, ReportsTo, PhotoPath)
EmployeeTerritories (EmployeeID, TerritoryID)
Order Details (OrderID, ProductID, UnitPrice, Quantity, Discount)
Orders (OrderID, CustomerID, EmployeeID, OrderDate, RequiredDate, ShippedDate, ShipVia, Freight, ShipName, ShipAddress, ShipCity, ShipRegion, ShipPostalCode, ShipCountry)
Products (ProductID, ProductName, SupplierID, CategoryID, QuantityPerUnit, UnitPrice, UnitsInStock, UnitsOnOrder, ReorderLevel, Discontinued)
Region (RegionID, RegionDescription)
Shippers (ShipperID, CompanyName, Phone)
Suppliers (SupplierID, CompanyName, ContactName, ContactTitle, Address, City, Region, PostalCode, Country, Phone, Fax, HomePage)
Territories (TerritoryID, TerritoryDescription, RegionID)</code></pre>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Hidden fields for JavaScript -->
<input type="hidden" id="questionId" value="<%= question.id %>">
<input type="hidden" id="solutionUnlocked" value="<%= solutionUnlocked %>">


<!-- JavaScript for SQL Editor -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const sqlQuery = document.getElementById('sqlQuery');
        const executeBtn = document.getElementById('executeQueryBtn');
        const clearBtn = document.getElementById('clearQueryBtn');
        const questionId = document.getElementById('questionId').value;
        const resultsSection = document.getElementById('results-section');
        const executionStatus = document.getElementById('execution-status');
        const resultsTable = document.getElementById('results-table');
        const resultsThead = document.getElementById('results-thead');
        const resultsTbody = document.getElementById('results-tbody');
        const feedbackBox = document.getElementById('feedback-box');
        const differencesList = document.getElementById('differences-list');
        const differencesContainer = document.getElementById('differences-container');
        const completionBadge = document.getElementById('completion-badge');
        let solutionUnlocked = document.getElementById('solutionUnlocked')?.value === 'true';
        const referenceQueryContainer = document.getElementById('reference-query-container');
        const referenceQueryElement = document.getElementById('reference-query');
        const compareWithChatGPTBtn = document.getElementById('compareWithChatGPT');
        const chatgptAnalysis = document.getElementById('chatgpt-analysis');
        const chatgptLoading = document.getElementById('chatgpt-loading');
        const chatgptContent = document.getElementById('chatgpt-content');
        // Execute query button click
        executeBtn.addEventListener('click', async function () {
            const query = sqlQuery.value.trim();

            if (!query) {
                executionStatus.className = 'alert alert-warning';
                executionStatus.textContent = 'Please enter a SQL query to execute.';
                resultsSection.style.display = 'block';
                return;
            }

            try {
                // Show loading state
                executeBtn.disabled = true;
                executeBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span>Running...';
                executionStatus.className = 'alert alert-info';
                executionStatus.textContent = 'Executing your query...';
                resultsSection.style.display = 'block';

                // Send query to server
                const response = await fetch(`/questions/${questionId}/execute`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ query })
                });

                const result = await response.json();

                // Clear previous results
                resultsThead.innerHTML = '';
                resultsTbody.innerHTML = '';
                feedbackBox.innerHTML = '';
                differencesList.innerHTML = '';
                differencesContainer.style.display = 'none';

                // Always show the results section and execution status
                resultsSection.style.display = 'block';
                executionStatus.style.display = 'block';

                if (!result.success) {
                    // Handle API-level error
                    //alert(result.executionResult.error);
                    executionStatus.className = 'alert alert-danger';
                    let errorMessage = `<div class="error-details">`;

                    // Display the main error message
                    errorMessage += `<div class="mb-2"><strong>Error:</strong> ${result.executionResult.message || 'An error occurred'}</div>`;

                    // If there's an execution result with error details, display them
                    if (result.executionResult && !result.executionResult.success) {

                        errorMessage += `<div class="mt-2"><strong>Database Error:</strong> ${result.executionResult.message || 'Unknown database error'}</div>`;

                        // Add the full error string if available
                        if (result.executionResult.error) {

                            errorMessage += `<div class="mt-2"><strong>Technical Details:</strong><br><code>${result.executionResult.error}</code></div>`;
                        }

                        // Add additional error details in a collapsible section
                        if (result.executionResult.errorCode || result.executionResult.errorState || result.executionResult.errorNumber) {

                            errorMessage += `<div class="mt-2">
                                <button class="btn btn-sm btn-outline-danger" type="button" data-bs-toggle="collapse" data-bs-target="#errorDetails">
                                    Show Additional Error Details
                                </button>
                                <div class="collapse mt-2" id="errorDetails">
                                    <div class="card card-body bg-light">
                                        ${result.executionResult.errorCode ? `<div><strong>Error Code:</strong> ${result.executionResult.errorCode}</div>` : ''}
                                        ${result.executionResult.errorState ? `<div><strong>SQL State:</strong> ${result.executionResult.errorState}</div>` : ''}
                                        ${result.executionResult.errorNumber ? `<div><strong>Error Number:</strong> ${result.executionResult.errorNumber}</div>` : ''}
                                    </div>
                                </div>
                            </div>`;
                        }
                    }

                    errorMessage += `</div>`;
                    executionStatus.innerHTML = errorMessage;

                    // Ensure the results section is visible and scroll to it
                    resultsSection.style.display = 'block';
                    resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    return;
                }

                // Handle the execution result
                const execResult = result.executionResult;
                const databaseName = result.databaseName || 'Unknown';

                if (execResult.success) {
                    // Query executed successfully
                    executionStatus.className = 'alert alert-success';
                    executionStatus.textContent = `Query executed successfully on ${databaseName} database. Returned ${execResult.rows} row(s).`;

                    // Populate the results table
                    resultsThead.innerHTML = '';
                    resultsTbody.innerHTML = '';

                    if (execResult.columns && execResult.columns.length > 0) {
                        // Create the table header
                        const headerRow = document.createElement('tr');
                        execResult.columns.forEach(column => {
                            const th = document.createElement('th');
                            th.textContent = column;
                            headerRow.appendChild(th);
                        });
                        resultsThead.appendChild(headerRow);

                        // Create the table rows
                        execResult.data.forEach(row => {
                            const tr = document.createElement('tr');
                            execResult.columns.forEach(column => {
                                const td = document.createElement('td');
                                td.textContent = row[column] !== null && row[column] !== undefined
                                    ? row[column]
                                    : 'NULL';
                                tr.appendChild(td);
                            });
                            resultsTbody.appendChild(tr);
                        });
                    } else {
                        resultsTbody.innerHTML = '<tr><td class="text-center">No results returned</td></tr>';
                    }
                } else {
                    // Query execution failed - display detailed error information
                    executionStatus.className = 'alert alert-danger';
                    let errorMessage = `<div class="error-details">`;

                    // Add the main error message in a more prominent way
                    errorMessage += `<div class="mb-2"><strong>Database Error:</strong> ${execResult.message}</div>`;

                    // Add the full error string if available (this contains the actual database error)
                    if (execResult.error) {
                        errorMessage += `<div class="mt-2"><strong>Technical Details:</strong><br><code>${execResult.error}</code></div>`;
                    }

                    // Add additional error details in a collapsible section
                    if (execResult.errorCode || execResult.errorState || execResult.errorNumber) {
                        errorMessage += `<div class="mt-2">
                            <button class="btn btn-sm btn-outline-danger" type="button" data-bs-toggle="collapse" data-bs-target="#errorDetails">
                                Show Additional Error Details
                            </button>
                            <div class="collapse mt-2" id="errorDetails">
                                <div class="card card-body bg-light">
                                    ${execResult.errorCode ? `<div><strong>Error Code:</strong> ${execResult.errorCode}</div>` : ''}
                                    ${execResult.errorState ? `<div><strong>SQL State:</strong> ${execResult.errorState}</div>` : ''}
                                    ${execResult.errorNumber ? `<div><strong>Error Number:</strong> ${execResult.errorNumber}</div>` : ''}
                                </div>
                            </div>
                        </div>`;
                    }

                    errorMessage += `</div>`;
                    executionStatus.innerHTML = errorMessage;
                }

                // Handle comparison results if available
                if (result.comparison) {
                    const comparison = result.comparison;

                    // Show feedback
                    feedbackBox.textContent = comparison.feedback;
                    feedbackBox.className = comparison.isCorrect
                        ? 'alert alert-success'
                        : 'alert alert-warning';

                    // Always show the match summary container
                    differencesContainer.style.display = 'block';
                    differencesList.innerHTML = '';

                    // Set the reference query (only if solution is unlocked)
                    if (solutionUnlocked && referenceQueryElement) {
                        if (result.executionResult && result.executionResult.solution) {
                            referenceQueryElement.textContent = result.executionResult.solution;
                        } else {
                            referenceQueryElement.textContent = 'Reference query not available';
                        }
                    }

                    // Add a header to summarize what matched/didn't match
                    const summaryLi = document.createElement('li');
                    summaryLi.className = 'list-group-item list-group-item-primary';
                    summaryLi.innerHTML = '<strong>Query Match Summary:</strong>';

                    // Add icons for row and column match status
                    if (comparison.rowsMatch) {
                        summaryLi.innerHTML += ' <span class="text-success"><i class="bi bi-check-circle"></i> Rows match</span>';
                    } else {
                        summaryLi.innerHTML += ' <span class="text-danger"><i class="bi bi-x-circle"></i> Rows differ</span>';
                    }

                    if (comparison.columnsMatch && comparison.columnNamesMatch) {
                        summaryLi.innerHTML += ' <span class="text-success"><i class="bi bi-check-circle"></i> Columns match</span>';
                    } else {
                        summaryLi.innerHTML += ' <span class="text-danger"><i class="bi bi-x-circle"></i> Columns differ</span>';
                    }

                    differencesList.appendChild(summaryLi);

                    // Show differences if any
                    if (comparison.differences && comparison.differences.length > 0) {
                        // Add individual differences
                        const differencesHeaderLi = document.createElement('li');
                        differencesHeaderLi.className = 'list-group-item list-group-item-secondary';
                        differencesHeaderLi.innerHTML = '<strong>Differences Found:</strong>';
                        differencesList.appendChild(differencesHeaderLi);

                        comparison.differences.forEach(diff => {
                            const li = document.createElement('li');
                            li.className = 'list-group-item';
                            li.textContent = diff;
                            differencesList.appendChild(li);
                        });
                    } else if (comparison.isCorrect) {
                        // If there are no differences and the query is correct, add a success message
                        const perfectMatchLi = document.createElement('li');
                        perfectMatchLi.className = 'list-group-item list-group-item-success';
                        perfectMatchLi.innerHTML = '<i class="bi bi-award"></i> <strong>Perfect match!</strong> Your query returns exactly the same results as the reference solution.';
                        differencesList.appendChild(perfectMatchLi);
                    }
                }

                // Handle completion status update
                if (result.isCompleted && !result.pastDeadline) {
                    // Update badge
                    const badge = document.getElementById('completion-badge');
                    if (badge) {
                        badge.className = 'badge rounded-pill px-3 py-2 completion-badge-complete';
                        badge.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> Completed';
                    }
                    // Hide the unlock progress label
                    const unlockLabel = document.getElementById('unlock-progress-label');
                    if (unlockLabel) unlockLabel.style.display = 'none';

                    window.sstToast('success', '✓ Question completed! Nice work.', 6000);

                    feedbackBox.className = 'alert mb-3';
                    feedbackBox.style.cssText = 'background:#f0fdf4; border:1px solid #bbf7d0; color:#15803d;';
                    feedbackBox.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i><strong>Question completed.</strong> Your query matches the expected output.<% if (typeof nextId !== "undefined" && nextId) { %> <a href="/questions/<%= nextId %>" class="ms-2 fw-medium" style="color:#15803d;">Next question →</a><% } %>';
                }

                // Handle past-deadline notices
                if (result.pastDeadline && feedbackBox) {
                    const sep = feedbackBox.innerHTML ? '<br>' : '';
                    if (result.isCompleted) {
                        feedbackBox.innerHTML += sep + '<span class="text-warning"><i class="bi bi-clock-history me-1"></i>Your query is correct, but the deadline for this topic has passed. Your answer was not counted toward your completion record.</span>';
                    } else {
                        feedbackBox.innerHTML += sep + '<span class="text-secondary"><i class="bi bi-clock-history me-1"></i>This topic\'s deadline has passed. You can continue to practice, but completions are no longer recorded.</span>';
                    }
                }

                // Update solution unlock state after every execute
                if (result.solutionUnlocked !== undefined) {
                    const lockNotice = document.getElementById('solution-lock-notice');
                    const solutionSection = document.getElementById('solution-section');
                    const solutionUnlockedInput = document.getElementById('solutionUnlocked');

                    if (result.solutionUnlocked && !solutionUnlocked) {
                        // Transition: locked → unlocked
                        solutionUnlocked = true;
                        if (solutionUnlockedInput) solutionUnlockedInput.value = 'true';
                        if (lockNotice) lockNotice.style.display = 'none';
                        if (solutionSection) solutionSection.style.display = '';
                        // Inject the solution footer into the AI panel card if it isn't there yet
                        const aiCard = document.querySelector('.col-md-4 .card');
                        if (aiCard && !document.getElementById('showReferenceQueryBtn')) {
                            const footer = document.createElement('div');
                            footer.className = 'card-footer bg-transparent border-top pt-2';
                            const solution = (result.executionResult && result.executionResult.solution) || '';
                            footer.innerHTML = `
                                <div id="reference-query-container" style="display:none;">
                                    <pre class="bg-light p-2 rounded mb-2" style="font-size:12px;"><code id="reference-query">${solution.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</code></pre>
                                </div>
                                <div class="d-flex gap-2 flex-wrap">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="showReferenceQueryBtn">
                                        <i class="bi bi-code-square me-1"></i>
                                        <span id="showReferenceQueryLabel">Show solution</span>
                                    </button>
                                    <button id="compareWithChatGPT" class="btn btn-sm btn-primary">
                                        <i class="bi bi-robot me-1"></i>Compare with AI
                                    </button>
                                </div>
                                <div id="chatgpt-analysis" class="mt-3" style="display:none;">
                                    <div id="chatgpt-loading" class="text-center" style="display:none;"></div>
                                    <div id="chatgpt-content"></div>
                                </div>`;
                            aiCard.appendChild(footer);
                            // Wire up the newly-injected button listeners
                            document.getElementById('showReferenceQueryBtn').addEventListener('click', async function() {
                                const rc = document.getElementById('reference-query-container');
                                const lbl = document.getElementById('showReferenceQueryLabel');
                                const isVis = rc.style.display !== 'none';
                                rc.style.display = isVis ? 'none' : 'block';
                                if (lbl) lbl.textContent = isVis ? 'Show solution' : 'Hide solution';
                                if (!isVis && !revealLogged) {
                                    revealLogged = true;
                                    try { await fetch(`/questions/${questionId}/log-reveal`, { method: 'POST' }); } catch(e) {}
                                }
                            });
                            document.getElementById('compareWithChatGPT').addEventListener('click', async function() {
                                const uq = sqlQuery.value.trim();
                                const rq = document.getElementById('reference-query').textContent;
                                if (!uq || !rq) { window.sstToast('error', 'Both queries are required for comparison'); return; }
                                const cgLoad = document.getElementById('chatgpt-loading');
                                const cgContent = document.getElementById('chatgpt-content');
                                const cgAnalysis = document.getElementById('chatgpt-analysis');
                                try {
                                    cgLoad.style.display = 'block'; cgContent.innerHTML = ''; cgAnalysis.style.display = 'block';
                                    const r = await fetch(`/questions/${questionId}/analyze`, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({userQuery: uq, referenceQuery: rq}) });
                                    const data = await r.json();
                                    cgContent.innerHTML = data.success ? data.analysis : `<div class="alert alert-danger">${data.message || 'Failed'}</div>`;
                                } catch(e) { cgContent.innerHTML = '<div class="alert alert-danger">Failed. Please try again.</div>'; }
                                finally { cgLoad.style.display = 'none'; }
                            });
                        }
                        // Update header unlock label
                        const unlockLabel = document.getElementById('unlock-progress-label');
                        if (unlockLabel) {
                            unlockLabel.innerHTML = '<i class="bi bi-unlock me-1"></i>Solution unlocked';
                        }
                    } else if (!result.solutionUnlocked) {
                        // Still locked: update progress counter
                        if (lockNotice) {
                            const progressText = lockNotice.querySelector('small');
                            if (progressText) {
                                const count = result.attemptCount || 0;
                                const pct = result.bestRowMatchPct || 0;
                                progressText.textContent =
                                    `Current progress: ${count} attempt${count !== 1 ? 's' : ''}, best row match: ${pct}%`;
                            }
                        }
                        // Update header unlock label
                        const unlockLabel = document.getElementById('unlock-progress-label');
                        if (unlockLabel) {
                            const count = result.attemptCount || 0;
                            const pct = result.bestRowMatchPct || 0;
                            unlockLabel.innerHTML = `<i class="bi bi-lock me-1"></i>Solution: ${count}/5 attempts${count > 0 ? ', ' + pct + '% match' : ''}`;
                        }
                    }
                }

            } catch (error) {
                console.error('Error executing query:', error);
                executionStatus.className = 'alert alert-danger';
                executionStatus.textContent = 'An error occurred while executing the query. Please try again.';
            } finally {
                // Reset button state — must match markup in sql-editor-toolbar above
                executeBtn.disabled = false;
                executeBtn.innerHTML = '<i class="bi bi-play-fill me-2"></i> Execute Query';
            }
        });

        // Clear button click
        clearBtn.addEventListener('click', function () {
            sqlQuery.value = '';
            sqlQuery.focus();
        });

        // Ctrl+Enter / Cmd+Enter to execute
        sqlQuery.addEventListener('keydown', function (e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                e.preventDefault();
                executeBtn.click();
            }
        });

        // Show/hide reference query toggle button (in AI panel footer)
        let revealLogged = false;
        const showRefBtn = document.getElementById('showReferenceQueryBtn');
        const showRefLabel = document.getElementById('showReferenceQueryLabel');
        if (showRefBtn) {
            showRefBtn.addEventListener('click', async function () {
                const isVisible = referenceQueryContainer.style.display !== 'none';
                referenceQueryContainer.style.display = isVisible ? 'none' : 'block';
                if (showRefLabel) showRefLabel.textContent = isVisible ? 'Show solution' : 'Hide solution';
                if (!isVisible && !revealLogged) {
                    revealLogged = true;
                    try { await fetch(`/questions/${questionId}/log-reveal`, { method: 'POST' }); } catch(e) {}
                }
            });
        }

        // Add event listener for ChatGPT comparison (only when solution is unlocked)
        if (compareWithChatGPTBtn) compareWithChatGPTBtn.addEventListener('click', async function () {
            const userQuery = sqlQuery.value.trim();
            const referenceQuery = referenceQueryElement.textContent;

            if (!userQuery || !referenceQuery) {
                window.sstToast('error', 'Both queries are required for comparison');
                return;
            }

            try {
                // Show loading state
                chatgptLoading.style.display = 'block';
                chatgptContent.innerHTML = '';
                chatgptAnalysis.style.display = 'block';

                // Send queries to server for ChatGPT analysis
                const response = await fetch(`/questions/${questionId}/analyze`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        userQuery,
                        referenceQuery
                    })
                });

                const result = await response.json();

                if (result.success) {
                    chatgptContent.innerHTML = result.analysis;
                } else {
                    chatgptContent.innerHTML = `<div class="alert alert-danger">${result.message || 'Failed to analyze queries'}</div>`;
                }
            } catch (error) {
                console.error('Error analyzing queries:', error);
                chatgptContent.innerHTML = '<div class="alert alert-danger">Failed to analyze queries. Please try again.</div>';
            } finally {
                chatgptLoading.style.display = 'none';
            }
        });

        // On-demand AI feedback button
        const aiFeedbackBtn = document.getElementById('aiFeedbackBtn');
        const aiFeedbackPanel = document.getElementById('realtime-feedback');
        const aiFeedbackLoading = document.getElementById('realtime-loading');

        aiFeedbackBtn.addEventListener('click', async function () {
            const query = sqlQuery.value.trim();
            if (!query) {
                aiFeedbackPanel.innerHTML = '<div class="text-muted"><i class="bi bi-robot"></i> Enter a query first.</div>';
                return;
            }
            aiFeedbackBtn.disabled = true;
            aiFeedbackBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span>Analyzing...';
            aiFeedbackLoading.style.display = 'block';
            aiFeedbackPanel.innerHTML = '';
            try {
                const response = await fetch(`/questions/${questionId}/analyze-syntax`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ query })
                });
                const result = await response.json();
                if (result.success) {
                    aiFeedbackPanel.innerHTML = result.analysis;
                } else {
                    aiFeedbackPanel.innerHTML = `<div class="alert alert-warning">${result.message || 'Failed to analyze query'}</div>`;
                }
            } catch (error) {
                console.error('Error getting AI feedback:', error);
                aiFeedbackPanel.innerHTML = '<div class="alert alert-danger">Failed to get feedback. Please try again.</div>';
            } finally {
                aiFeedbackLoading.style.display = 'none';
                aiFeedbackBtn.disabled = false;
                aiFeedbackBtn.innerHTML = '<i class="bi bi-robot me-1"></i> Get AI Feedback';
            }
        });

        // Character counter
        sqlQuery.addEventListener('input', function () {
            const counter = document.getElementById('query-char-count');
            if (counter) counter.textContent = this.value.length > 0 ? this.value.length + ' chars' : '';
        });
    });
</script>